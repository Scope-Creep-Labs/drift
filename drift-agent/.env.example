# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...

# --- VictoriaMetrics ---
# Base URL the agent uses to query metrics. For docker-compose default
# (with profile=demo), this is http://victoriametrics:8428.
VM_URL=http://victoriametrics:8428

# Path prefix for vmselect/cluster mode. Leave empty for single-node VM.
# Example for cluster: /select/0/prometheus
VM_TENANT_PATH=

# Optional auth (basic or bearer). Leave both empty for none.
VM_BASIC_AUTH=
VM_BEARER_TOKEN=

# --- LLM ---
MODEL=claude-opus-4-7
EFFORT=high
MAX_TOKENS=64000

# --- CORS for local frontend dev ---
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
