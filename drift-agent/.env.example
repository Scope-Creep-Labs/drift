# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...

# --- VictoriaMetrics ---
# Base URL the agent uses to query metrics.
# Examples:
#   VM_URL=https://vm.example.com
#   VM_URL=http://localhost:8428              # local-dev uvicorn against host VM
#   VM_URL=http://host.docker.internal:8428   # docker-compose against host VM
VM_URL=

# Path prefix for vmselect/cluster mode. Leave empty for single-node VM.
# Example for cluster: /select/0/prometheus
VM_TENANT_PATH=

# Optional auth (basic or bearer). Leave both empty for none.
VM_BASIC_AUTH=
VM_BEARER_TOKEN=

# --- LLM ---
MODEL=claude-opus-4-7
EFFORT=high
MAX_TOKENS=64000

# --- CORS for local frontend dev ---
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Session cookie scope ---
# Empty (default) = host-scoped — the cookie only goes back to the exact
# host where you logged in (fine for local uvicorn on localhost).
#
# Set to a domain (e.g. dabba.princesamuel.me) in production so the same
# session cookie reaches every subdomain — required for the tunnel
# feature's owner-check middleware on tunnel-*.<domain> proxies.
# install.sh writes this for you in fresh installs.
SESSION_COOKIE_DOMAIN=
