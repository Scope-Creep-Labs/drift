# Copy to .env and fill in. .env is gitignored.

# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...

# --- VictoriaMetrics ---
# Default points at the in-compose VM service (only running with --profile demo).
# Override with your real VictoriaMetrics URL when not using the demo profile.
# Examples:
#   VM_URL=https://vm.example.com
#   VM_URL=http://100.64.0.1:8428      # over Tailscale
VM_URL=http://victoriametrics:8428

# Cluster mode (vmselect) prefix. Empty for single-node VM.
# Example: /select/0/prometheus
VM_TENANT_PATH=

# Optional auth — leave both empty for none.
VM_BASIC_AUTH=          # username:password
VM_BEARER_TOKEN=        # opaque token (Authorization: Bearer ...)

# --- LLM ---
MODEL=claude-opus-4-7
EFFORT=high
MAX_TOKENS=64000
