# Copy to .env and fill in. .env is gitignored.

# --- LLM ---
# Drift routes through LiteLLM. Set MODEL to any LiteLLM-supported model
# id; only the API key for that provider's vendor needs to be filled in.
# EFFORT applies to Anthropic models (extended-thinking budget); MAX_TOKENS
# caps a single completion across all providers.
#
# Examples:
#   MODEL=claude-opus-4-7      → set ANTHROPIC_API_KEY
#   MODEL=gpt-4o               → set OPENAI_API_KEY
#   MODEL=o3                   → set OPENAI_API_KEY
#   MODEL=gemini-2.5-pro       → set GEMINI_API_KEY
MODEL=claude-opus-4-7
EFFORT=high
MAX_TOKENS=64000
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- VictoriaMetrics ---
# Base URL of your Prometheus-compatible TSDB. Examples:
#   VM_URL=https://vm.example.com
#   VM_URL=http://100.64.0.1:8428      # over Tailscale
#   VM_URL=http://host.docker.internal:8428   # VM running on the docker host
VM_URL=

# Cluster mode (vmselect) prefix. Empty for single-node VM.
# Example: /select/0/prometheus
VM_TENANT_PATH=

# Optional auth — leave both empty for none.
VM_BASIC_AUTH=          # username:password
VM_BEARER_TOKEN=        # opaque token (Authorization: Bearer ...)

# --- Alerting (optional) ---
# Point Drift at vmalert + Alertmanager so it can list rules, see firing
# alerts, and create/delete silences. Leave URLs empty to disable the
# alert tools cleanly. Paths must include any reverse-proxy prefix the
# services serve at (e.g. /vmalert, /am).
#   VMALERT_URL=https://drift.example.com/vmalert
#   ALERTMANAGER_URL=https://drift.example.com/am
VMALERT_URL=
VMALERT_BASIC_AUTH=        # username:password (for caddy / vmauth in front)
ALERTMANAGER_URL=
ALERTMANAGER_BASIC_AUTH=

# --- VictoriaLogs (logs subsystem) ---
# Drift's query_logs tool sends LogsQL queries here. The same vmauth user
# `reporter` typically gates both VM writes and VL queries via url_map.
#   VL_URL=https://drift.example.com/vl
#   VL_BASIC_AUTH=reporter:<REDACTED>   (or whatever your vmauth creds are)
VL_URL=
VL_BASIC_AUTH=

# Host path bind-mounted into drift-agent at /etc/alerts so the agent can
# write `drift-managed.yml` and trigger a vmalert reload. Leave default if
# you're co-located with the VM stack at /root/setup/victoria/.
VMALERT_RULES_HOST_DIR=/root/setup/victoria/alerts

# Alertmanager config file (rw mount) and per-receiver secrets dir (ro mount)
# bind-mounted into drift-agent. The agent edits alertmanager.yml directly to
# manage receivers/routes, but only ever references secrets BY FILENAME — it
# never reads the secret contents.
#
# To add a webhook secret:
#   echo -n 'tk_xxxxxxxxxxxxxxxxxxxxxx' > /root/setup/victoria/am-secrets/ntfy-default
#   chmod 640 /root/setup/victoria/am-secrets/ntfy-default
# Then ask Drift to upsert a receiver referencing `ntfy-default`.
ALERTMANAGER_CONFIG_HOST_FILE=/root/setup/victoria/alertmanager.yml
ALERTMANAGER_SECRETS_HOST_DIR=/root/setup/victoria/am-secrets

# --- Drift Deploy (control plane state + bundle storage) ---
# Postgres for devices/apps/revisions/deployment_targets.
DRIFT_PG_USER=drift
DRIFT_PG_DB=drift
DRIFT_PG_PASSWORD=                    # required if running the deploy stack
# Override only if you point at an external Postgres; otherwise the default
# in docker-compose builds the URL from the three vars above.
# DRIFT_PG_URL=postgresql+asyncpg://user:pass@host:5432/db

# B2 (or any S3-compatible) bucket for compose bundle tarballs.
B2_ENDPOINT=https://s3.us-west-002.backblazeb2.com
B2_REGION=us-west-002
B2_ACCESS_KEY_ID=
B2_SECRET_ACCESS_KEY=
B2_BUCKET=
B2_PREFIX=drift-bundles               # all objects are prefixed with this

# --- Secrets (registry creds + future env-var secrets) ---
# Fernet key for encrypting stored credentials at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty to disable the secrets endpoints.
DRIFT_SECRET_KEY=

# --- Auth / first admin user ---
# Bootstrap admin account, ensured on every startup (created if missing,
# password reset if different). Required at first deploy so the system
# isn't locked out; subsequent admins are managed via the /api/auth/users
# endpoints.
DRIFT_ADMIN_USERNAME=
DRIFT_ADMIN_PASSWORD=

# When true, session cookies are sent without Secure so plain-http
# localhost dev works. Production should leave this false (default).
# DEV_MODE=false

