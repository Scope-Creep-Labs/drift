# Copy to .env and fill in. .env is gitignored.

# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...

# --- VictoriaMetrics ---
# Base URL of your Prometheus-compatible TSDB. Examples:
#   VM_URL=https://vm.example.com
#   VM_URL=http://100.64.0.1:8428      # over Tailscale
#   VM_URL=http://host.docker.internal:8428   # VM running on the docker host
VM_URL=

# Cluster mode (vmselect) prefix. Empty for single-node VM.
# Example: /select/0/prometheus
VM_TENANT_PATH=

# Optional auth — leave both empty for none.
VM_BASIC_AUTH=          # username:password
VM_BEARER_TOKEN=        # opaque token (Authorization: Bearer ...)

# --- LLM ---
MODEL=claude-opus-4-7
EFFORT=high
MAX_TOKENS=64000
