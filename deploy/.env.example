# Drift single-server bundle — environment.
#
# Don't edit this directly. Run `./install.sh` from the deploy/ dir; it
# prompts for the values it needs and writes .env for you. Re-run it
# any time to rotate credentials or reconfigure.
#
# Everything below is documented here for reference / manual overrides.

# --- Public-facing ---
# Public DNS name (A/AAAA record must already point at this host).
DOMAIN=drift.example.com
# Used for Let's Encrypt ACME registration.
LETSENCRYPT_EMAIL=ops@example.com

# --- vmalert / Alertmanager UI password ---
# Basic-auth credential that gates the raw vmalert + Alertmanager
# web UIs. NOT your Drift admin login — that's DRIFT_ADMIN_PASSWORD
# below. The two are independent. The hash here is bcrypt; install.sh
# computes it via the caddy:2 image, and also stashes the plaintext
# so reruns can prefill the prompt.
WEB_AUTH_USER=drift
WEB_AUTH_PASSWORD_PLAINTEXT=
WEB_AUTH_HASH=

# --- LLM ---
# litellm-supported model id; set the matching *_API_KEY below.
#   MODEL=claude-opus-4-7      → ANTHROPIC_API_KEY
#   MODEL=gpt-4o / gpt-4o-mini → OPENAI_API_KEY
#   MODEL=o3 / o3-mini         → OPENAI_API_KEY
#   MODEL=gemini-2.5-pro       → GEMINI_API_KEY
MODEL=claude-opus-4-7
EFFORT=high
MAX_TOKENS=64000
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Drift admin (bootstrap account, created/updated on every startup) ---
DRIFT_ADMIN_USERNAME=admin
DRIFT_ADMIN_PASSWORD=

# --- Drift Postgres ---
DRIFT_PG_USER=drift
DRIFT_PG_DB=drift
DRIFT_PG_PASSWORD=

# --- Secrets (Fernet key for registry credentials encryption at rest) ---
DRIFT_SECRET_KEY=

# --- ntfy ---
# Alertmanager alerts get pushed to https://ntfy.sh/<NTFY_TOPIC>.
NTFY_TOPIC=

# --- vmauth `reporter` user (remote vmagents push metrics here) ---
REPORTER_PASSWORD=

# --- Self-scrape (this host) ---
REPORTER_HOSTNAME=drift-host
REPORTER_GROUP=cloud

# --- Retention ---
VM_RETENTION=90d
VL_RETENTION=30d

# --- B2 / S3 bundle storage (only used by Drift Deploy) ---
# Leave empty to keep Drift Deploy's bundle uploads dormant. Bundle pushes
# from chat will surface a clear "storage not configured" error.
B2_ENDPOINT=
B2_REGION=
B2_ACCESS_KEY_ID=
B2_SECRET_ACCESS_KEY=
B2_BUCKET=
B2_PREFIX=drift-bundles

# --- VM auth from drift-agent to local VM (not used in single-server) ---
# Leave both empty; drift-agent talks to vm:8428 directly inside the network.
VM_BASIC_AUTH=
VM_BEARER_TOKEN=
